{
  "cli": {
    "version": ">= 13.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development",
      "env": {
        "APP_ENV": "development",
        "SANCTUARY_DIORAMA": "1"
      }
    },
    "preview": {
      "distribution": "internal",
      "channel": "preview",
      "autoIncrement": true,
      "env": {
        "APP_ENV": "preview",
        "SANCTUARY_DIORAMA": "1"
      }
    },
    "play-internal": {
      "channel": "play-internal",
      "autoIncrement": true,
      "android": {
        "buildType": "app-bundle"
      },
      "env": {
        "APP_ENV": "play-internal",
        "SANCTUARY_DIORAMA": "0"
      }
    },
    "production": {
      "channel": "production",
      "autoIncrement": true,
      "env": {
        "APP_ENV": "production",
        "SANCTUARY_DIORAMA": "0"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
