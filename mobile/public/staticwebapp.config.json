{
  "routes": [
    {
      "route": "/auth/callback",
      "methods": ["GET"],
      "rewrite": "/auth/callback.html",
      "headers": {
        "Cache-Control": "no-store",
        "Referrer-Policy": "no-referrer",
        "X-Content-Type-Options": "nosniff"
      }
    },
    {
      "route": "/classroom",
      "methods": ["GET"],
      "redirect": "/groups",
      "statusCode": 302
    }
  ]
}
