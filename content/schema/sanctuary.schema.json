        "$ref": "#/$defs/Soundscape"
      },
      "title": "Soundscapes",
      "type": "array"
    },
    "tiny_surprises": {
      "items": {
        "$ref": "#/$defs/TinySurprise"
      },
      "title": "Tiny Surprises",
      "type": "array"
    },
    "zones": {
      "items": {
        "$ref": "#/$defs/SanctuaryZone"
      },
      "minItems": 1,
      "title": "Zones",
      "type": "array"
    }
