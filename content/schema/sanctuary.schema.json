            10
          ],
          "title": "Threshold",
          "type": "integer"
        },
        "zone": {
          "enum": [
            "meadow",
            "woodland",
            "pond",
            "sky",
            "soil",
            "urban",
            "elsewhere"
          ],
          "title": "Zone",
          "type": "string"
