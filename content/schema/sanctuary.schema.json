        "mood": {
          "maxLength": 180,
          "minLength": 1,
          "title": "Mood",
          "type": "string"
        },
        "title": {
          "maxLength": 60,
          "minLength": 1,
          "title": "Title",
          "type": "string"
        }
      },
      "required": [
        "id",
        "title",
        "mood"
