      },
      "required": [
        "id",
        "zone",
        "threshold",
        "description"
      ],
      "title": "TinySurprise",
      "type": "object"
    }
  },
  "description": "The whole sanctuary content tree, assembled for cross-reference checks.\n\nPer-file validation happens in `scripts/validate_content.py` against\nthe individual element models above. After per-file validation passes,\nthe validator gathers all instances into this wrapper to enforce\ncross-file invariants: id uniqueness across element kinds, and the\nexistence of every referenced id / zone.\n\n`model_validator(mode=\"after\")` is the one intentional divergence from\nthe expedition pattern: cross-file id resolution needs every list-field\ntyped and validated before it runs, which `field_validator` cannot\nexpress in a single check.",
  "properties": {
    "charismatic_unlocks": {
      "items": {
        "$ref": "#/$defs/CharismaticUnlock"
      },
      "title": "Charismatic Unlocks",
      "type": "array"
    },
    "coarse_unlocks": {
