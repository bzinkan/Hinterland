{
  "$defs": {
    "CharismaticUnlock": {
      "description": "Charismatic single-taxon unlock keyed by a verified iNat taxon_id.\n\n`taxon_id_verified` defaults to False; authors must set it true only\nafter manually confirming the numeric id on inaturalist.org. Content\nwith `taxon_id_verified=false` is acceptable as a draft but MUST be\nflipped to true before any production release. Enforcement of that\nrule at build time is a follow-up PR (see PR description).",
      "properties": {
        "common_name": {
          "maxLength": 60,
          "minLength": 1,
          "title": "Common Name",
          "type": "string"
        },
        "detail": {
          "maxLength": 180,
          "minLength": 1,
          "title": "Detail",
          "type": "string"
        },
        "icon": {
          "maxLength": 120,
          "minLength": 1,
          "title": "Icon",
          "type": "string"
        },
        "id": {
          "title": "Id",
          "type": "string"
        },
        "taxon_id": {
          "minimum": 1,
          "title": "Taxon Id",
          "type": "integer"
        },
        "taxon_id_verified": {
          "default": false,
          "title": "Taxon Id Verified",
          "type": "boolean"
        },
        "title": {
          "maxLength": 60,
          "minLength": 1,
          "title": "Title",
          "type": "string"
        },
        "zone": {
          "enum": [
            "meadow",
            "woodland",
            "pond",
            "sky",
            "soil",
            "urban",
            "elsewhere"
          ],
          "title": "Zone",
          "type": "string"
        }
      },
      "required": [
        "id",
        "zone",
        "taxon_id",
        "common_name",
        "title",
        "detail",
        "icon"
      ],
      "title": "CharismaticUnlock",
      "type": "object"
    },
    "CoarseUnlock": {
      "description": "Broad-category sanctuary element keyed by one or more iNat iconic taxa.",
      "properties": {
        "detail": {
          "maxLength": 180,
          "minLength": 1,
          "title": "Detail",
          "type": "string"
        },
        "icon": {
          "maxLength": 120,
          "minLength": 1,
          "title": "Icon",
          "type": "string"
        },
        "iconic_taxa": {
          "items": {
            "enum": [
              "Plantae",
              "Insecta",
              "Aves",
              "Mammalia",
              "Amphibia",
              "Reptilia",
              "Actinopterygii",
              "Mollusca",
              "Annelida",
              "Arachnida",
              "Fungi",
              "Chromista",
              "Protozoa",
              "unknown"
            ],
            "type": "string"
          },
          "minItems": 1,
          "title": "Iconic Taxa",
          "type": "array"
        },
        "id": {
          "title": "Id",
          "type": "string"
        },
        "title": {
          "maxLength": 60,
          "minLength": 1,
          "title": "Title",
          "type": "string"
        },
        "zone": {
          "enum": [
            "meadow",
            "woodland",
            "pond",
            "sky",
            "soil",
            "urban",
            "elsewhere"
          ],
          "title": "Zone",
