      },
      "title": "Guide Lines",
      "type": "array"
    },
    "identity_reflections": {
      "items": {
        "$ref": "#/$defs/IdentityReflection"
      },
      "title": "Identity Reflections",
      "type": "array"
    },
    "mystery_cues": {
      "items": {
        "$ref": "#/$defs/MysteryCue"
      },
      "title": "Mystery Cues",
      "type": "array"
    },
    "relationship_moments": {
      "items": {
