DRAGONFLY_ENV=local
DRAGONFLY_LOG_LEVEL=INFO
DRAGONFLY_CORS_ORIGINS=["http://localhost:19006"]
DRAGONFLY_GCP_PROJECT_ID=dragonflyapp-495423
DRAGONFLY_PHOTOS_BUCKET=dragonfly-photos-local
DRAGONFLY_OBSERVATION_IDEMPOTENCY_REQUIRED=false
DRAGONFLY_STORAGE_EMULATOR_HOST=
DRAGONFLY_CLOUD_SQL_INSTANCE=
DRAGONFLY_DATABASE_HOST=localhost
DRAGONFLY_DATABASE_PORT=5432
DRAGONFLY_DATABASE_NAME=dragonfly
DRAGONFLY_DATABASE_USER=dragonfly
DRAGONFLY_DATABASE_PASSWORD=dragonfly
DRAGONFLY_DATABASE_PASSWORD_SECRET=
DRAGONFLY_DATABASE_POOL_SIZE=5
DRAGONFLY_DATABASE_MAX_OVERFLOW=2
DRAGONFLY_DATABASE_ECHO_SQL=false
DRAGONFLY_READINESS_DATABASE_REQUIRED=false
# Every setting also accepts the preferred HINTERLAND_ prefix; when both
# exist, HINTERLAND_ wins and DRAGONFLY_ remains a compatibility fallback.
DRAGONFLY_INAT_CV_ENABLED=false
DRAGONFLY_INAT_CV_DISCLOSURE_APPROVED=false
DRAGONFLY_INAT_CV_BENCHMARK_APPROVED=false
DRAGONFLY_INAT_CV_MODEL_VERSION=inat-cv-v1
DRAGONFLY_INAT_SUBMIT_ENABLED=false
DRAGONFLY_MODERATION_PROVIDER=noop
DRAGONFLY_TAXONOMY_PACKS_BUCKET=taxonomy-packs
